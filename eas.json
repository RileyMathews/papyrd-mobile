{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "internal": {
      "channel": "internal",
      "autoIncrement": true
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "internal": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "groups": ["Internal Testers"]
      }
    },
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
